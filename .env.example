# Frontend (Vite) - these are safe to expose (anon/public keys)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Backend (Fastify API) - leave empty, fetched from Supabase secrets at runtime
PORT=3001
SERP_API_KEY=""
GEMINI_API_KEY=""
REDIS_URL=""
CORS_ORIGIN="http://localhost:8080"

# Supabase - service role key is SECRET, never commit the real value
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
